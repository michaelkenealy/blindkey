{
  "name": "@blindkey/core",
  "version": "0.1.0",
  "description": "Core cryptographic primitives and types for BlindKey credential management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "encryption",
    "aes-256-gcm",
    "credentials",
    "security",
    "cryptography",
    "policy",
    "audit"
  ],
  "author": "Michael Kenealy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelkenealy/blindkey.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/michaelkenealy/blindkey#readme",
  "bugs": {
    "url": "https://github.com/michaelkenealy/blindkey/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
