# BlindKey Local Mode Configuration
# Copy to .env and customize

# Vault storage location (default: ~/.blindkey)
# BLINDKEY_DIR=~/.blindkey

# Master encryption key (auto-generated on first run if not set)
# VAULT_MASTER_KEY=

# Local API server port (default: 3200)
# LOCAL_API_PORT=3200

# Fail-open policy mode (default: false — fail-closed is recommended)
# POLICY_FAIL_OPEN=false

# Audit log signing key (optional — enables HMAC signatures on audit entries)
# AUDIT_SIGNING_KEY=
